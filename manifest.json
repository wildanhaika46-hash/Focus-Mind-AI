{
  "manifest_version": 3,
  "name": "FocusMind AI",
  "description": "AI-powered Chrome Extension to boost focus, summarize, rewrite, proofread, and translate for students & professionals. Built with Gemini Nano.",
  "version": "1.0.0",
  "minimum_chrome_version": "120",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "ai"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "public/index.html",
    "default_icon": {
      "16": "",
      "32": "",
      "48": "",
      "128": ""
    }
  },
  "options_page": "public/options.html",
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/messageHandler.js"],
      "run_at": "document_idle"
    }
  ]
}
